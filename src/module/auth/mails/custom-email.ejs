<!DOCTYPE html>
<html lang="en">

<head>
    <title>Highlightz | Notification</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>

<body style="margin:0; padding:0; background-color:#F0F9F0; font-family:Segoe UI, Tahoma, Geneva, Verdana, sans-serif;">

    <div style="max-width:600px; margin:30px auto; background:#ffffff; border-radius:16px; overflow:hidden; border:2px solid #32CD32;">

        <!-- Header -->
        <div style="background:#121212; text-align:center; padding:30px 20px;">
            <img 
                src="https://i.postimg.cc/0jzTdT8t/Whats-App-Image-2026-03-17-at-10-31-34.jpg" 
                alt="Highlightz Logo"
                style="max-width:180px; height:auto; display:block; margin:0 auto;"
            />
        </div>

        <!-- Body -->
        <div style="padding:35px 30px; line-height:1.7; color:#333;">
            
            <p style="font-size:20px; font-weight:700; margin:0 0 15px; color:#121212;">
                Hi <%= userName %>,
            </p>

            <div style="font-size:16px; margin-top:10px;">
                <%- content %>
            </div>

        </div>

        <!-- Footer -->
        <div style="background:#F9F9F9; padding:20px 25px; text-align:center; font-size:13px; color:#666; border-top:1px solid #eee;">
            
            <p style="margin:0 0 8px;">
                Need help? 
                <a href="mailto:support@highlightz.com" style="color:#32CD32; text-decoration:none; font-weight:bold;">
                    Contact Support
                </a>
            </p>

            <p style="margin:0;">
                &copy; 2026 Highlightz Platform. All rights reserved.
            </p>

        </div>

    </div>

</body>

</html>